{
  "category": "OS",
  "description": "Sistemas Operacionais homologados para o Fluig",
  "rules": [
    {
      "field": "os_name",
      "label": "Sistema Operacional",
      "homologated": [
        { "name": "Red Hat Enterprise Linux", "versions": ["8.x", "9.x"] },
        { "name": "Ubuntu Server", "versions": ["20.04 LTS", "22.04 LTS"] },
        { "name": "Windows Server", "versions": ["2019", "2022"] },
        { "name": "Oracle Linux", "versions": ["8.x", "9.x"] }
      ],
      "restricted": [
        { "name": "Windows Server", "versions": ["2016"], "reason": "Suporte encerrando, recomendar upgrade" },
        { "name": "CentOS", "versions": ["7.x"], "reason": "EOL, migrar para RHEL ou Oracle Linux" }
      ],
      "not_homologated": [
        { "name": "Windows Server", "versions": ["2012", "2012 R2"] },
        { "name": "Debian", "versions": ["*"] },
        { "name": "SUSE", "versions": ["*"] }
      ],
      "comparison": "name_version"
    },
    {
      "field": "architecture",
      "label": "Arquitetura",
      "homologated": ["x86_64", "64-bit", "64"],
      "restricted": [],
      "not_homologated": ["x86", "32-bit", "32", "i386"],
      "comparison": "exact"
    }
  ]
}
